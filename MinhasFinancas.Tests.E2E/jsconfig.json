{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@base/*": ["./src/base/*"],
      "@features/*": ["./src/features/*"]
    },
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "types": ["node"]
  },
  "include": ["src/**/*", "vitest.config.ts"],
  "exclude": ["node_modules", "dist"]
}