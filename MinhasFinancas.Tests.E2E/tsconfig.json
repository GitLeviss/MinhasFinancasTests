{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": ".",
    "types": ["node"],
    "paths": {
      "@base/*": ["./src/base/*"],
      "@features/*": ["./src/features/*"]
    }
  },
  "include": ["src/**/*.ts", "vitest.config.ts"]
}